<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Admin Dashboard</title>
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/manage/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/manage/assets/vendors/ti-icons/css/themify-icons.css">
    <link rel="stylesheet" href="~/manage/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/manage/assets/vendors/font-awesome/css/font-awesome.min.css">
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/manage/assets/vendors/bootstrap-datepicker/bootstrap-datepicker.min.css">
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/manage/assets/css/style.css">
    <link rel="shortcut icon" href="~/manage/assets/images/favicon.png"/>
</head>
<body>
<div class="container-scroller">
    <!-- Pro Banner -->
    <!-- Navbar -->
    <nav class="navbar default-layout-navbar col-lg-12 col-12 p-0 fixed-top d-flex flex-row">
        <div class="text-center navbar-brand-wrapper d-flex align-items-center justify-content-start">
            <a class="navbar-brand brand-logo" href="#">
                <img src="~/manage/assets/images/logo.svg" alt="logo"/>
            </a>
            <a class="navbar-brand brand-logo-mini" href="#">
                <img src="~/manage/assets/images/logo-mini.svg" alt="logo"/>
            </a>
        </div>
        <div class="navbar-menu-wrapper d-flex align-items-stretch">
            <button class="navbar-toggler navbar-toggler align-self-center" type="button" data-toggle="minimize">
                <span class="mdi mdi-menu"></span>
            </button>
            <ul class="navbar-nav navbar-nav-right">
                <li class="nav-item nav-profile dropdown">
                    <a class="nav-link dropdown-toggle" id="profileDropdown" href="#" data-bs-toggle="dropdown"
                       aria-expanded="false">
                        <div class="nav-profile-img">
                            <img src="~/manage/assets/images/faces/face1.jpg" alt="image">
                            <span class="availability-status online"></span>
                        </div>
                        <div class="nav-profile-text">
                            <p class="mb-1 text-black">Admin User</p>
                        </div>
                    </a>
                    <div class="dropdown-menu navbar-dropdown" aria-labelledby="profileDropdown">
                        <a class="dropdown-item" href="#">
                            <i class="mdi mdi-logout me-2 text-primary"></i> Signout
                        </a>
                    </div>
                </li>
            </ul>
            <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button"
                    data-toggle="offcanvas">
                <span class="mdi mdi-menu"></span>
            </button>
        </div>
    </nav>
    <!-- Sidebar & Content -->
    <div class="container-fluid page-body-wrapper">
        <!-- Sidebar -->
        <nav class="sidebar sidebar-offcanvas" id="sidebar">
            <ul class="nav">
                <li class="nav-item nav-profile">
                    <a href="#" class="nav-link">
                        <div class="nav-profile-image">
                            <img src="~/manage/assets/images/faces/face1.jpg" alt="profile"/>
                            <span class="login-status online"></span>
                        </div>
                        <div class="nav-profile-text d-flex flex-column">
                            <span class="font-weight-bold mb-2">Admin</span>
                            <span class="text-secondary text-small">Administrator</span>
                        </div>
                        <i class="mdi mdi-bookmark-check text-success nav-profile-badge"></i>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                        <span class="menu-title">Dashboard</span>
                        <i class="mdi mdi-home menu-icon"></i>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Author" asp-action="Index">
                        <span class="menu-title">Author</span>
                        <i class="mdi mdi-book menu-icon"></i>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Book" asp-action="Index">
                        <span class="menu-title">Books</span>
                        <i class="mdi mdi-book menu-icon"></i>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Slider" asp-action="Index">
                        <span class="menu-title">Slider</span>
                        <i class="mdi mdi-image menu-icon"></i>
                    </a>
                </li>
            </ul>
        </nav>
        <!-- Main Panel -->
        <div class="main-panel">
            <div class="content-wrapper">
                @RenderBody()
            </div>
            <!-- Footer -->
            <footer class="footer">
                <div class="d-sm-flex justify-content-center justify-content-sm-between">
                    <span class="text-muted text-center text-sm-left d-block d-sm-inline-block">
                        Copyright © 2024 <a href="#" target="_blank">Pustok</a>. All rights reserved.
                    </span>
                    <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center">
                        Made with <i class="mdi mdi-heart text-danger"></i>
                    </span>
                </div>
            </footer>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script src="~/manage/assets/vendors/js/vendor.bundle.base.js"></script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/manage/assets/vendors/chart.js/chart.umd.js"></script>
<script src="~/manage/assets/vendors/bootstrap-datepicker/bootstrap-datepicker.min.js"></script>

<script src="~/manage/assets/js/off-canvas.js"></script>
<script src="~/manage/assets/js/misc.js"></script>
<script src="~/manage/assets/js/settings.js"></script>
<script src="~/manage/assets/js/sidebar.js"></script>
<script src="~/manage/assets/js/jquery.cookie.js"></script>

@RenderSection("Scripts", required: false)
</body>
</html>