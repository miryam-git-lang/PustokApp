@model Slider
@{
    ViewData["Title"] = "Create Slider";
}

<div class="page-header">
    <h3 class="page-title">Create Slider</h3>
</div>

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">

                <form enctype="multipart/form-data" asp-action="Create" asp-area="Manage" method="post">

                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="Title"></label>
                        <input asp-for="Title" class="form-control"/>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Description"></label>
                        <input asp-for="Description" class="form-control"/>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="File"></label>
                        <input asp-for="File" class="form-control"/>
                        <span asp-validation-for="File" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="ButtonUrl"></label>
                        <input asp-for="ButtonUrl" class="form-control"/>
                        <span asp-validation-for="ButtonUrl" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ButtonText"></label>
                        <input asp-for="ButtonText" class="form-control"/>
                        <span asp-validation-for="ButtonText" class="text-danger"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-primary mt-3">
                        Create
                    </button>

                    <a asp-action="Index" class="btn btn-light mt-3">
                        Cancel
                    </a>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial"/>
}
