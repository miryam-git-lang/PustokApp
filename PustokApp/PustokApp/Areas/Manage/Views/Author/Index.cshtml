@model List<Author>
@{
    ViewData["Title"] = "Author";
    Layout = "~/Areas/Manage/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h3 class="page-title">
        <span class="page-title-icon bg-gradient-primary text-white me-2">
            <i class="mdi mdi-account-multiple"></i>
        </span> Authors
    </h3>
</div>

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="card-title m-0">Author List</h4>
                    <a asp-action="Create" class="btn btn-sm btn-primary">Create New</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Full Name</th>
                            <th>Books</th>
                            <th>Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        @if (Model.Count > 0)
                        {
                            foreach (var author in Model)
                            {
                                <tr>
                                    <td>@author.Id</td>
                                    <td>@author.FullName</td>
                                    <td>@(author.Books?.Count ?? 0)</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@author.Id" class="btn btn-sm btn-warning">
                                            Edit
                                        </a>

                                        <a asp-action="Details"
                                           asp-route-id="@author.Id"
                                           asp-area="Manage"
                                           class="btn btn-sm btn-info author-details">
                                            Details
                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@author.Id"
                                              asp-area="Manage"
                                              method="post"
                                              class="d-inline-block">

                                            @Html.AntiForgeryToken()

                                            <button type="submit" class="btn btn-sm btn-danger deleteAuthor">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">No authors found.</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="authorDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="authorDetailsModalContent"></div>
    </div>
</div>

@section Scripts
{
    <script>
        $(document).on("click", ".author-details", function (event) {
            event.preventDefault();
            let url = $(this).attr("href");
            fetch(url)
                .then(res => res.text())
                .then(html => {
                    $("#authorDetailsModalContent").html(html);

                    let modal = new bootstrap.Modal(document.getElementById("authorDetailsModal"));
                    modal.show();
                });
        });

        $(document).on("click", ".deleteAuthor", function (event) {
            event.preventDefault();

            let form = $(this).closest("form");

            Swal.fire({
                title: "Are you sure?",
                showCancelButton: true,
                confirmButtonText: "Delete",
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                } else {
                    Swal.fire("Cancelled", "", "info");
                }
            });
        });
    </script>
}
